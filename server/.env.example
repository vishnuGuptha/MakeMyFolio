PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio-cms
# Production: required, ≥32 chars, must not be "dev-secret" or this example value
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_EMAIL=admin@portfolio.local
ADMIN_PASSWORD=admin123

# Local frontend origin. Production example: https://buildmyfolio.com
# (or https://www.buildmyfolio.com if that is your canonical host)
CLIENT_URL=http://localhost:5173

# Apex domain — CORS allows apex, www, and *.{APP_DOMAIN} (portfolio subdomains).
# Auth cookies stay host-only (no Domain=) while /api is same-origin via Vercel rewrites.
# Do not set a cookie Domain unless the API moves to a separate host.
APP_DOMAIN=buildmyfolio.com

UPLOAD_DIR=uploads

# Media storage: local | cloudinary | s3 (omit to auto-detect from credentials below)
STORAGE_PROVIDER=local

# Cloudinary (recommended for images/PDFs without managing buckets)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=portfolio

# S3 or S3-compatible (MinIO, R2, etc.) — prefer Node 20+
# S3_BUCKET=
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_PUBLIC_URL=

# Password reset: optional webhook POST { email, resetUrl, name }; logs in server console otherwise
# RESET_EMAIL_WEBHOOK=
# Include resetUrl in JSON response (local/dev helpers only)
# RESET_TOKEN_IN_RESPONSE=1

# Contact form → owner email: POST JSON { type: "contact_message", to, visitorName, visitorEmail, message, portfolioName, inboxUrl, subject }
# Prefer CONTACT_EMAIL_WEBHOOK; falls back to EMAIL_WEBHOOK. Logs to console when unset.
# CONTACT_EMAIL_WEBHOOK=
# EMAIL_WEBHOOK=

# Payment receipt → buyer email: POST JSON { type: "payment_receipt", to, orderId, planName, amountFormatted, receiptUrl, … }
# Prefer RECEIPT_EMAIL_WEBHOOK; falls back to EMAIL_WEBHOOK. Logs to console when unset.
# RECEIPT_EMAIL_WEBHOOK=

GEMINI_API_KEY=your-gemini-api-key-here
# Use a current model. Leave blank to auto-try fallbacks.
GEMINI_MODEL=gemini-2.5-flash

# --- Billing ---
# USD → Stripe Checkout (test keys: sk_test_… / whsec_… from Stripe CLI or Dashboard)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Forward webhooks locally: stripe listen --forward-to localhost:4000/api/billing/stripe/webhook

# INR → Razorpay (test keys from Razorpay Dashboard → API Keys)
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
