{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://makemyfolio-env.eba-w63ctmap.ap-south-1.elasticbeanstalk.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://makemyfolio-env.eba-w63ctmap.ap-south-1.elasticbeanstalk.com/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "destination": "/index.html"
    }
  ]
}
