# Local: leave empty (Vite proxies /api → localhost:4000).
# Vercel: leave unset/empty and use client/vercel.json rewrites to EB.
# Or set to a full https:// API origin if you skip the Vercel proxy.
# Do not point the browser at a separate API host unless cookies/CORS are updated.
VITE_API_URL=

# Apex domain (marketing + dashboard). Default in code: buildmyfolio.com
VITE_APP_DOMAIN=buildmyfolio.com

# Portfolio public URLs
# - Production: omit this, or set `subdomain` → https://vishnu.buildmyfolio.com
# - Local only: set `path` → http://127.0.0.1:5173/vishnu (no wildcard DNS needed)
# Do NOT set `path` on Vercel production.
VITE_PORTFOLIO_URL_MODE=subdomain
